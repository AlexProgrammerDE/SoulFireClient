{
  "name": "soulfire",
  "version": "2.8.1",
  "description": "Frontend client for SoulFire.",
  "author": "Pistonmaster",
  "desktopName": "soulfire.desktop",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "dev": "cross-env SF_ELECTRON=1 vite",
    "dev:web": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "build:electron": "cross-env SF_ELECTRON=1 vite build && electron-builder --publish never",
    "build:electron:dir": "cross-env SF_ELECTRON=1 vite build && electron-builder --dir --publish never",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fix": "biome check --write --unsafe",
    "check": "biome check",
    "generate-proto": "tsx generate-proto.ts",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@aptabase/react": "^0.4.0",
    "@base-ui/react": "^1.4.0",
    "@bufbuild/protobuf": "^2.11.0",
    "@catppuccin/palette": "^1.8.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/query-broadcast-client-experimental": "^5.99.0",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "5.100.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/table-core": "^8.21.3",
    "@xyflow/react": "^12.10.2",
    "adm-zip": "^0.5.17",
    "bonjour-service": "^1.3.0",
    "castv2-client": "^1.2.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-flag-icons": "^1.6.16",
    "date-fns": "^4.1.0",
    "discord-rpc": "^4.0.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "embla-carousel-react": "^8.6.0",
    "fancy-ansi": "^0.1.3",
    "file-saver": "^2.0.5",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "input-otp": "^1.4.2",
    "js-sha256": "^0.11.1",
    "lucide-react": "^1.8.0",
    "lucide-static": "^1.8.0",
    "mime-matcher": "^1.0.5",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "next-themes": "^0.4.6",
    "node-addon-api": "^8.7.0",
    "nuqs": "2.8.9",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-number-format": "^5.4.5",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tar": "^7.5.13",
    "tw-animate-css": "^1.4.0",
    "urijs": "^1.19.11",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "webdav": "^5.9.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "2.4.14",
    "@bufbuild/buf": "^1.68.2",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form-devtools": "^0.2.21",
    "@tanstack/react-router": "^1.168.22",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-cli": "^1.166.33",
    "@tanstack/router-plugin": "^1.167.22",
    "@types/babel__core": "^7.20.5",
    "@types/file-saver": "^2.0.7",
    "@types/loadable__component": "^5.13.10",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/urijs": "^1.19.26",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "react-hooks": "^1.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-svgr": "^5.2.0"
  },
  "lint-staged": {
    "*": [
      "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "build": {
    "appId": "com.soulfiremc.soulfire",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": true,
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "release-artifacts"
    },
    "files": [
      "build/icons/**",
      "dist/**",
      "dist-electron/**",
      "locales/**",
      "public/**",
      "package.json",
      "soulfire-server-version.txt"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://github.com/soulfiremc-com/SoulFireClient/releases/latest/download"
    },
    "linux": {
      "category": "Development",
      "desktop": {
        "entry": {
          "StartupWMClass": "soulfire",
          "X-GNOME-WMClass": "soulfire"
        }
      },
      "executableName": "soulfire",
      "icon": "build/icons",
      "maintainer": "SoulFire <security@soulfiremc.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": "-",
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false
    },
    "productName": "SoulFire",
    "protocols": [
      {
        "name": "SoulFire",
        "schemes": [
          "soulfire"
        ]
      }
    ],
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis"
      ]
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@bufbuild/buf",
      "@swc/core",
      "@tailwindcss/oxide",
      "core-js",
      "electron",
      "esbuild",
      "msw",
      "workerd"
    ]
  }
}
